<%- include('partials/header') %>

<section class="card">
  <div class="card-head">
    <h1>グループ</h1>
  </div>
  <p class="muted">旅行やシェアハウスなど、割り勘したい単位でグループを作りましょう。</p>

  <form action="/groups" method="post" class="form-inline">
    <input type="text" name="name" placeholder="グループ名(例: 夏合宿)" required>
    <button type="submit" class="btn btn-primary">グループを作る</button>
  </form>

  <% if (groups.length === 0) { %>
    <p class="muted">まだグループがありません。</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>グループ名</th><th>メンバー</th><th></th></tr>
      </thead>
      <tbody>
        <% groups.forEach((g) => { %>
          <tr>
            <td><%= g.name %></td>
            <td><%= g.members.map((m) => m.user.name).join('、') %></td>
            <td class="actions"><a href="/groups/<%= g.id %>" class="btn btn-small btn-secondary">開く</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
