<%- include('partials/header') %>

<section class="card">
  <div class="card-head">
    <h1>支出一覧</h1>
    <a href="/expenses/new" class="btn btn-primary">+ 支出を記録</a>
  </div>

  <% if (expenses.length === 0) { %>
    <p class="muted">まだ支出がありません。「支出を記録」から追加してみましょう。</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>いつ</th>
          <th>何に</th>
          <th>カテゴリ</th>
          <th>区分</th>
          <th class="num">いくら</th>
          <th>誰が</th>
          <th>グループ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% expenses.forEach((e) => { %>
          <tr>
            <td><%= formatDate(e.spentAt) %></td>
            <td class="memo-cell"><%= e.memo %></td>
            <td><span class="tag"><%= e.category.name %></span></td>
            <td>
              <span class="tag <%= e.isEssential ? 'tag-essential' : 'tag-optional' %>">
                <%= e.isEssential ? '必需' : '嗜好' %>
              </span>
            </td>
            <td class="num"><%= yen(e.amount) %></td>
            <td><%= e.user.name %></td>
            <td><%= e.group ? e.group.name : '—' %></td>
            <td class="actions">
              <a href="/expenses/<%= e.id %>/edit" class="btn btn-small btn-secondary">編集</a>
              <form action="/expenses/<%= e.id %>/delete" method="post" class="inline">
                <button type="submit" class="btn btn-small btn-danger">削除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
